    return;

end;      


handler Navdownkeypressed;
--Declaration Section

begin

    UpdateDisplay;

    return;

end;



  
handler User1Keypressed;
--Declaration Section
Bit : integer;

begin    

    GetDigin(0,1,Bit);
    if Bit=1 then --Estop has been pressed
      SetLabelText(Lbl4S1,"Batch Stopped");
      SetLabelText(Lbl5S1,"Batch Halted by E-Stop");
      SetSoftkeyText(1,"Resume");
      SetSoftkeyText(2,""); 
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"");
    
      if g_Level=0 then
        
        SetSoftkeyText(3,"");
        g_Level:=3;
          
      elsif g_Level=8 then
        
        SetSoftkeyText(3,"Abort Batch");
        g_Level:=2;
          
      end if;
        
    else 
    
      if g_Level=0 then
        
        if g_Manual=1 then
                
          g_Manual:=0;
          SetDigout(0,3,0);
          
        end if;  
          
        g_Level:=8;
        SetBatch;
                      
      elsif g_Level=2 then    -- Resume Processing.
        
        g_Level:=8;
        StartBatch;                              
      
      elsif g_Level=3 then   -- Return to Beginning.
    
        g_Level:=0;
        
      elsif g_Level=5 then  -- Setpoint mismatch brought us here.  Reset and return.
      
        ResetBatch;
        g_CurrentSp:=0;
        g_Level:=0;
        ClearTare(1);
        SetMode(Scale1,GrossMode);
      
      elsif g_Level=9 then  --  Finished with batching
      
        PromptForBatch;
        
      end if;
    
    end if;
       
    UpdateDisplay;
    
    return;

end;

  
handler User2Keypressed;
--Declaration Section
CutOff : real;

begin

     GetSPValue(g_FillSP,CutOff);                           
     if g_Level=8 then
       StopBatch;
       SelectScreen(1);
       SetNumericValue(Num1S1,CutOff);
       SetNumericValue(Num2S1,g_Target);
       SetLabelText(Lbl4S1,"Batch Stopped");
       SetLabelText(Lbl5S1,"Batch Halted by User");
       SetSoftkeyText(1,"Resume");
       SetSoftkeyText(2,""); 
       SetSoftkeyText(3,"Abort Batch");
       SetSoftkeyText(4,"");
       SetSoftkeyText(5,"");
       g_Level:=2;             
     end if;     
     
    return;

end;

handler User3Keypressed;
--Declaration Section
Bit : integer;

begin
    
     GetDigin(0,1,Bit);
     if Bit=1 then --Estop has been pressed
       SetLabelText(Lbl4S1,"Batch Stopped");
       SetLabelText(Lbl5S1,"Batch Halted by E-Stop");
       SetSoftkeyText(1,"Resume");
       SetSoftkeyText(2,""); 
       SetSoftkeyText(4,"");
       SetSoftkeyText(5,"");
       if g_Level=0 then
         
         g_Level:=3;
         
       end if;
       
    else
       
      if g_Level=0 or g_Level=9 then
         
        if g_Manual=0 then
        
          g_Manual:=1;
          
        else
        
          g_Manual:=0;
          
        end if;
        
        SetDigout(0,3,g_Manual);
        
      elsif g_Level=2 then
        
        g_CurrentSp:=0;
        g_SubLevel:=0;
        g_Level:=0;
        
        ClearTare(1);
        SetMode(Scale1,GrossMode);
        ResetBatch;
        
      end if;
      
    end if;
      
    UpdateDisplay;  

    return;

end;

handler User4Keypressed;
--Declaration Section

begin

    if g_Level=0 then
      
      g_SubLevel:=1;     -- Set Variable to identify entry as Cutoff
      PromptUser("New CutOff:");
       
    end if; 
    return;

end;



handler User5Keypressed;
--Declaration Section

begin
    
    if g_Level=0 then
      
      g_SubLevel:=2;    -- Set Variable to identify entry as Target
      PromptUser("New Target:");
       
    end if; 
    return;

end;






 handler Numerickeypressed;
----Declaration Section

begin

    return;

end;



 handler Userentry;
--Declaration Section
UserString :string;
UserReal : real;
EntryString : string;
rPreact : real;
SetupDB : SetupDBDatabase;

begin
                          
    UserString := GetEntry;
    ClosePrompt;          
    EnableHandelers;
    UserReal:=StringToReal(UserString);

    if EventKey = EnterKey   then          

      if g_Level=0 then    -- No batching is in progress
      
        if UserString<>""then    -- Make sure the user entered something.
          
          if g_SubLevel=1 then   -- User is entering new Cutoff value.
            
            if UserReal > g_Target then   -- Make sure that the Cutoff is not greater than your target.
              
              SelectScreen(1);
              SetNumericValue(Num1S1,g_CutOff);
              SetNumericValue(Num2S1,g_Target);
              SetLabelText(Lbl4S1,"Input Error");
              SetLabelText(Lbl5S1,"Cut Off Too Large");
              SetSoftkeyText(1,"Resume");
              SetSoftkeyText(2,""); 
              SetSoftkeyText(3,"");
              SetSoftkeyText(4,"");
              SetSoftkeyText(5,"");
              g_Level:=3;           
            
            else
              
              g_Cutoff:=UserReal; -- Update the Cutoff global variable.
              rPreAct:=g_Target-g_Cutoff; 
              
              SetupDB.GetFirst;
              SetupDB.PreAct:=rPreAct;
              SetupDB.Update;
              
              SetSPPreact(g_FillSP,rPreact);  -- Update the preact value on the setpoint
            
            end if; 
          
          end if;
          
          if g_SubLevel=2 then    -- User is entering new Target value.
            
            if UserReal < g_CutOff then  -- If the Target is Less than the CutOff point
            
              SelectScreen(1);
              SetNumericValue(Num1S1,g_CutOff);
              SetNumericValue(Num2S1,g_Target);
              SetLabelText(Lbl4S1,"Input Error");
              SetLabelText(Lbl5S1,"Target Too Small");
              SetSoftkeyText(1,"Resume");
              SetSoftkeyText(2,""); 
              SetSoftkeyText(3,"");
              SetSoftkeyText(4,"");
              SetSoftkeyText(5,"");
              g_Level:=3;           
            
            else
              
              g_Target:=UserReal;  -- Update the Target variable. 
              SetSPValue(g_Fillsp,g_Target);
              SetupDB.GetFirst;
              SetupDB.Target:=g_Target;
              SetupDB.Update;
              
            end if;             
          end if;
        end if;
      end if;
    end if;  
                               
    UpdateDisplay;
    return;
end;

    



handler Digins0B1DeActivate; --EStop Activated
--Declaration Section
BS : BatchStatus;                

begin

    GetBatchStatus(BS);
    
    if BS= BatchRunning then
    
      PauseBatch;
    
    end if;
    
    if g_Manual=1 then   -- If E-stop is activated while manual control is on.
     
      SetDigout(0,3,0); -- Turn off digital out 3
      
    end if;
    
    UpdateDisplay; 
    return;

end;


handler Digins0B1Activate; --EStop DeActivated
--Declaration Section


begin
    UpdateDisplay; 
    return;

end;






  
handler Digins0B2Activate; --Select Switch Bit 1 Activated
--Declaration Section
Bit : integer;

begin    

    GetDigin(0,1,Bit);
    if Bit=1 then --Estop has been pressed
      SetLabelText(Lbl4S1,"Batch Stopped");
      SetLabelText(Lbl5S1,"Batch Halted by E-Stop");
      SetSoftkeyText(1,"Resume");
      SetSoftkeyText(2,""); 
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"");
    
      if g_Level=0 then
        
        SetSoftkeyText(3,"");
        g_Level:=3;
          
      elsif g_Level=8 then
        
        SetSoftkeyText(3,"Abort Batch");
        g_Level:=2;
          
      end if;
        
    else 
    
      if g_Level=0 then          
               
        if g_Manual=1 then
        
          g_Manual:=0;
          SetDigout(0,3,0);
          
        end if;
               
        g_Level:=8;
        SetBatch;
                      
      elsif g_Level=2 then    -- Resume Processing.
        
        g_Level:=8;
        StartBatch;                              
      
      elsif g_Level=3 then   -- Return to Beginning.
    
        g_Level:=0;
        
      elsif g_Level=5 then  -- Setpoint mismatch brought us here.  Reset and return.
      
        ResetBatch;
        g_CurrentSp:=0;
        g_Level:=0;
        ClearTare(1);
        SetMode(Scale1,GrossMode);
      
      elsif g_Level=9 then   --  Finished with Batching
             
        PromptForBatch;
              
      end if;
    
    end if;
       
    UpdateDisplay;
    
    return;

end;


