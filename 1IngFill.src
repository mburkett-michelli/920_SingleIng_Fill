--                       Batching Stuff

------------------------------------------------------------------------------- 

procedure SetBatch;
--Declaration Section
Setpt : integer;
SpValue : real;
CutOff : real;
Bit : integer;        
CurPreact : real;                                  
Factor : real;

Gross : real;
begin

    GetSPValue(g_FillSP,CutOff); 
    GetGross(Scale1,Primary,Gross);
    GetDigin(0,1,Bit);
    if Bit=1 then    
    
       SelectScreen(1);
       SetNumericValue(Num1S1,CutOff);
       SetNumericValue(Num2S1,g_Target);
       SetLabelText(Lbl4S1,"Emergency Stop Pressed");
       SetLabelText(Lbl5S1,"Batch Aborted");
       SetSoftkeyText(1,"Return");
       SetSoftkeyText(2,"");
       SetSoftkeyText(3,"");
       SetSoftkeyText(4,"");
       SetSoftkeyText(5,"");
       g_Level:=3;
    
    elsif Gross<50 and Gross >-50 then
    
       --  Batch Start Selected, Display message to inform them that process has started
       GetGross(Scale1,Primary,Gross);

       if Gross <=0 then
    
         ZeroScale(scale1);
    
       else
    
         TareScale; 
    
       end if;  
       
       if StartBatch<>SysOk then
       
         SelectScreen(1);
         SetNumericValue(Num1S1,CutOff);
         SetNumericValue(Num2S1,g_Target);
         SetLabelText(Lbl4S1,"StartBatch Failed");
         SetLabelText(Lbl5S1,"");
         SetSoftkeyText(1,"Return");
         SetSoftkeyText(2,""); 
         SetSoftkeyText(3,"");
         SetSoftkeyText(4,"");
         SetSoftkeyText(5,"");
         g_Level:=3;
         
       else
         
         SelectScreen(1);
         SetNumericValue(Num1S1,CutOff);
         SetNumericValue(Num2S1,g_Target);
         SetLabelText(Lbl4S1,"Batch Starting");
         SetLabelText(Lbl5S1,"");
         SetSoftkeyText(1,"");
         SetSoftkeyText(2,"Stop Batch"); 
         SetSoftkeyText(3,"");
         SetSoftkeyText(4,"");
         SetSoftkeyText(5,"");
         g_Level:=8;
         SetMode(Scale1, NetMode);
         StartBatch;
         
       end if;           
       
    else
       
       SelectScreen(1);
       SetNumericValue(Num1S1,CutOff);
       SetNumericValue(Num2S1,g_Target);
       SetLabelText(Lbl4S1,"Scale Not At Zero");
       SetLabelText(Lbl5S1,"Scale must be within 50lbs of Zero");
       SetSoftkeyText(1,"Return");
       SetSoftkeyText(2,""); 
       SetSoftkeyText(3,"");
       SetSoftkeyText(4,"");
       SetSoftkeyText(5,"");
       g_Level:=3;
       
    end if;
    
    UpdateDisplay;        
    
    return;

end;




-------------------------------------------------------------------------------

--                   End Of Batching Stuff

------------------------------------------------------------------------------- 








