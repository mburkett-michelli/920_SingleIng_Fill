handler Timer1Trip;--Update Display
--Declaration Section
CurrentSp : integer;
begin  

    if (g_Level=8 and g_SubLevel=0) or g_Level=9 then
--      GetCurrentSP(CurrentSp);
--       if g_CurrentSP <>CurrentSp then
         UpdateDisplay;   
--       else
--          StartTimer(1);   
--       end if;    
    end if;
    return;

end;


handler Timer2Trip;--Update BarGraph
--Declaration Section

Scale : real;       
CurrentSp : integer;              
BLevel : integer;
CurrentMode : Mode;

begin   
--    GetCurrentSP(CurrentSp);
--    if CurrentSp=7 or CurrentSp=12 or CurrentSp=17  
--       or CurrentSp=22 or CurrentSp=27 or CurrentSp=32 
--       or CurrentSp=37 then
--        WriteLn(2,"We Paused The Scale at Setpoint "+IntegerToString( CurrentSp,0));
--       StartBatch;
--    end if;
--
  GetMode(scale1,CurrentMode);
  
  if CurrentMode=NetMode then  
    
    GetNet(Scale1,Primary,Scale);
    
  elsif CurrentMode=GrossMode then
  
    GetGross(Scale1,Primary,Scale);
    
  end if;
   
  if g_Target>0 then
    BLevel:=(Scale/g_Target)*100;
  else                            
    BLevel:=0;
  end if;
    
  if BLevel>100 then 
     BLevel:=100;
  end if;

  SetBargraphLevel(Bar1S1,BLevel);
  UpdateDisplay;

  return;

end;



