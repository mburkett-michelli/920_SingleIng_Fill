------------------------------------------------------------------------------
-- This chunk of code is the system startup event handler.
SetupDB : SetupDBDatabase;

begin

  SetTimer(2,50);
  SetTimerMode(2,TimerContinuous );
  StartTimer(2);
   
  -- Initialize all global variables here.
  
  g_FillSP:=2;  -- Identifies the setpoint for flow control.
  g_HighestSP:=3;  -- Identifies the highest setpoint for program control.
  
  if SetupDB.GetFirst<>SysOk then --Cant Find the Setup Record so Make some Default Values
  
    SetupDB.Target:=3684;
    SetupDB.PreAct:=0;
    SetupDB.Add;
    
  end if;
  
  g_Target:=SetupDB.Target;
  g_Cutoff:=SetupDB.Target-SetupDB.PreAct;
  
  if g_Target < 0 then
  
    g_Target:=0;
    
  end if;
  
  if g_Cutoff < 0 or g_Cutoff > g_Target then
  
    g_Cutoff:=g_Target;
    
  end if;
  
  -- Increment the build number every time you make a change and recompile.
  g_iBuild := 12; 

  UpdateDisplay;     
  -- Display the version number to the display.
  DisplayVersion;
   

end Blending_Hopper; 
-- This name must match the name following "program" keyword at 
-- the beginning of the program.

