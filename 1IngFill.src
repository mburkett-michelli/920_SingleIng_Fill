program Blending_Hopper;

#include import.iri  

  ----------------------------------------------------------------------------
  -- Begin constants and aliases definitions here.
  
  g_csProgName : constant string := "Fill Program";  
  g_csVersion : constant string := "01.00";
 
  -- End of constants and aliases.
  ----------------------------------------------------------------------------
  

  ----------------------------------------------------------------------------
  -- Begin user created types (enumerations, records, arrays) definitions.
 -- type StringArray is array[50] of string;
 -- type RealArray is array[20] of real;
  

  -- End of user created types (enumerations, records, arrays).
  ----------------------------------------------------------------------------



  ----------------------------------------------------------------------------
  -- Start global variables definitions here.  Don't forget to initialize 
  -- them in the system startup event handler.
  
  g_iBuild       : integer;
  g_srcResult    : SysCode;   
  g_Count : integer;
  
  g_Level : integer :=0;
  g_CountMax : integer :=25; 
  g_SubLevel : integer :=0;
  g_BitStatus : integer;
  g_CurrentRation :  string := "";  
  g_CurIngredient : string;
  g_RecordCount : integer;    
  g_CurrentSp : integer;
  g_FillSP: integer; -- Identifies the Setpoint used for flow control
  g_Manual : integer; -- Toggle for manual dump on / off
  g_Target : real; 
  g_Cutoff : real;
  g_CurSpValue : real;
  g_HighestSP : integer;
  
  
  

  -- End of global variables.    
  ----------------------------------------------------------------------------


  ----------------------------------------------------------------------------
  -- Start functions and procedures definitions here.    

procedure TareScale;
--Declaration Section
lCount : integer;
lindex : integer;             
Net : real ;


begin 
   
     lCount:=0;
      WriteLn(2,"Taring Scale");

     loop
       
       lCount:=lCount+1;   
       if AcquireTare(Scale1)=SysOk then
       
         GetNet(scale1,Primary,Net);
          WriteLn(2,"Count: "+IntegerToString(lCount,0)+"  Net: "+IntegerToString(Net,0));
         if Net<5 then
       
            WriteLn(2,"Net within 5 of zero  Net = "+IntegerToString(Net,0));
           
           exit;
       
         end if;
       
          WriteLn(2,"Aquire Tare Good - Net not within 5 of Zero  Net = "+IntegerToString(Net,0));
       
       else                                                             
       
          WriteLn(2,"Aquire Tare Fail - Current Net = "+IntegerToString(Net,0));
         
       end if;
       SetLabelText(Lbl5S1,"Taring Scale..."+IntegerToString(lCount,0));          
       if lCount>20 then
       
         g_SubLevel:=2;
         SetLabelText(Lbl4S1,"Error Taring Scale");
         SetLabelText(Lbl5S1,"Check the Tare");
         SetSoftkeyText(1,"Resume");
         SetSoftkeyText(2,"");
         SetSoftkeyText(3,"Cancel");
         SetSoftkeyText(4,"");
         SetSoftkeyText(5,"");
         exit;
       
       end if;
       -- Pause to give scale a chance to settle down
       for lindex := 1 to 5000
       loop
       
         if lindex=2500 then  -- Check scale at half way mark.
           if AcquireTare(Scale1)=SysOk then
             exit;
           end if;
         end if;
        
       end loop;  
       
     end loop;            
   
    return;

end;

procedure Debug (Stemp : string);
-- Declaration Section   


begin
               

    if g_Manual = 1 then
      
      WriteLn(2,Stemp);
      
    end if; 
          
  return;
  
end;


procedure EnableHandelers;
--Declaration Section

begin        
    EnableHandler(Numerickeypressed);
    EnableHandler(Navupkeypressed);
    EnableHandler(Navdownkeypressed);
    



    return;

end;


procedure DisableHandlers;
--Declaration Section

begin        
    DisableHandler(Numerickeypressed);
    DisableHandler(Navupkeypressed);
    DisableHandler(Navdownkeypressed);
    
    return;

end;

  
  function MakeVersionString : string; 
    
    sTemp : string;
    
  begin 
    
    if g_iBuild > 9 then
      sTemp := ("Ver " + g_csVersion + "." + IntegerToString(g_iBuild, 2));
    else
      sTemp := ("Ver " + g_csVersion + ".0" + IntegerToString(g_iBuild, 1));
    end if;
      
    return sTemp;
    
  end;

    
     
  procedure DisplayVersion; 
  
  begin
   
    DisplayStatus(g_csProgName + "  " + MakeVersionString);
  
  end;


  
procedure UpdateDisplay;
--Declaration Section

CutOff : real;
CurSpValue : real;
Bit : integer;
Net : real;   
Gross : real;
CurrentSp : integer;

begin
    
    if g_Level=0 then 

      SelectScreen(1);
      SetNumericValue(Num1S1,g_CutOff);
      SetNumericValue(Num2S1,g_Target);
      SetLabelText(Lbl4S1,"Idle");
      SetLabelText(lbl5S1,"");
      SetSoftkeyText(1,"Start Batch");
      SetSoftkeyText(2,""); 
      if g_Manual = 0 then
        
         SetSoftkeyText(3,"Bypass Off");
        
      else
      
         SetSoftkeyText(3,"Bypass On");
        
      end if;
      SetSoftkeyText(4,"Edit Cutoff");
      SetSoftkeyText(5,"Edit Target");
      
    

----Batching
      
    elsif g_Level=8 then -- Batching has started
      GetDigin(0,1,Bit);
       if Bit=1 then --Estop has been pressed
         SetLabelText(Lbl4S1,"Batch Stopped");
         SetLabelText(Lbl5S1,"Batch Halted by E-Stop");
         SetSoftkeyText(1,"Resume");
         SetSoftkeyText(2,""); 
         SetSoftkeyText(3,"Abort Batch");
         SetSoftkeyText(4,"");
         SetSoftkeyText(5,"");
         g_Level:=2;
                          
       else
       
          
          if GetCurrentSP(CurrentSp)<>SysOk then
             CurrentSp := g_CurrentSp;      
          end if;
          
--          WriteLn(2,"Setpoint = "+IntegerToString(CurrentSp,0));
--          WriteLn(2,"Global Setpoint = "+IntegerToString(g_CurrentSp,0)); 
          
          if CurrentSp=1 and g_CurrentSp>1  then
              ResetBatch;
              SetLabelText(Lbl4S1,"Setpoint Error");
              SetLabelText(Lbl5S1,"Batch Cannot Continue");
              g_Level:=5; -- If setpoint error flag with lvl5
              SetSoftkeyText(1,"Return");
              SetSoftkeyText(2,"");
              SetSoftkeyText(3,"");
              SetSoftkeyText(4,"");
              SetSoftkeyText(5,"");
              SetTimerMode(1,TimerOneShot);
              SetTimer(1,50);
              StartTimer(1);    
          else
          
              g_CurrentSp:=CurrentSp;
          
              SelectScreen(1);
              SetNumericValue(Num1S1,CutOff);
              SetNumericValue(Num2S1,g_Target);                 
                                         
              if CurrentSp=1 then
                 
                 SetLabelText(Lbl4S1,"Starting...");
                 SetLabelText(Lbl5S1,"");
                 SetSoftkeyText(1,"");
                 SetSoftkeyText(2,"Stop Batch");
                 SetSoftkeyText(3,"");
                 SetSoftkeyText(4,"");
                 SetSoftkeyText(5,"");
                 
              elsif CurrentSp=g_FillSP then                 
                 
                 SetLabelText(Lbl4S1,"Filling Hopper");
                 SetLabelText(Lbl5S1,"");
                 SetSoftkeyText(1,"");
                 SetSoftkeyText(2,"Stop Batch");
                 SetSoftkeyText(3,"");
                 SetSoftkeyText(4,"");
                 SetSoftkeyText(5,"");
                   
              elsif  CurrentSp=g_HighestSp then   
                                
                 SetLabelText(Lbl4S1,"Batch Completed");
                 SetLabelText(Lbl5S1,"");
                 SetSoftkeyText(1,"Finish");
                 SetSoftkeyText(2,"");
                 
                 if g_Manual = 0 then
                   
                   SetSoftkeyText(3,"Bypass Off");
                  
                 else
                
                   SetSoftkeyText(3,"Bypass On");
                  
                 end if;
                       
                 SetSoftkeyText(4,"");
                 SetSoftkeyText(5,"");
                 
                 g_Level:=9;
                  
              end if;
          
          end if;
             
       end if;   
    
    elsif g_Level=9 then
    
      GetDigin(0,1,Bit);
      if Bit=1 then --Estop has been pressed
        SetLabelText(Lbl4S1,"ByPass Stopped");
        SetLabelText(Lbl5S1,"ByPass Halted by E-Stop");
        SetSoftkeyText(1,"");
        SetSoftkeyText(2,"");
        g_Manual:=0; 
      
      else
      
        SetLabelText(Lbl4S1,"Batch Completed");
        SetLabelText(Lbl5S1,"");
        SetSoftkeyText(1,"Finish");
        SetSoftkeyText(2,"");
        
      end if;         
      if g_Manual = 0 then
                   
        SetSoftkeyText(3,"Bypass Off");
                  
      else
                
        SetSoftkeyText(3,"Bypass On");
                  
      end if;
                       
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"");
      
    end if;
      
    return;

end;

  
procedure PromptForBatch;
--Declaration Section

begin
      
      ClearTare(1);
      SetMode(Scale1,GrossMode);
      g_CurrentSp:=0;
      g_SubLevel:=0;
      g_Level:=0;
      g_Manual:=0;
      SetDigout(0,3,0);
      ResetBatch;

      UpdateDisplay;
    return;

end;


